<?xml version="1.0" encoding="utf-8"?>
<!-- Allow cleartext for local/self-hosted neko-server (MVP). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
